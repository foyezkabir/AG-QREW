# ============================================================
# QA Agent Team — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Test Environment (you provide these — project name + sprint come from Confluence) ---
STAGING_URL=https://staging.yourapp.com
TEST_ADMIN_EMAIL=admin@yourapp-test.com
TEST_ADMIN_PASSWORD=your-admin-password
TEST_USER_EMAIL=user@yourapp-test.com
TEST_USER_PASSWORD=your-user-password

# --- Jira (optional — leave blank if project is not on Jira) ---
# If JIRA_PROJECT_KEY is blank: bugs go to Confluence, retest is manual, no Jira polling.
JIRA_PROJECT_KEY=PROJ
JIRA_READY_FOR_QA_STATUS=Ready for QA
JIRA_DONE_STATUS=Done
JIRA_IN_PROGRESS_STATUS=In Progress
JIRA_BUG_ISSUE_TYPE=Bug
JIRA_POLL_INTERVAL_MINUTES=10

# --- Confluence (Atlassian MCP handles auth) ---
# Required: used to fetch release notes / BRDs and (if no Jira) to host the bug report page.
CONFLUENCE_SPACE_KEY=DEV
CONFLUENCE_RELEASE_NOTE_LABEL=release-note

# --- TestRail (secret — keep private) ---
TESTRAIL_BASE_URL=https://yourcompany.testrail.io
TESTRAIL_USERNAME=your@email.com
TESTRAIL_API_KEY=YOUR_TESTRAIL_API_KEY
TESTRAIL_PROJECT_ID=1
TESTRAIL_SUITE_ID=1

# --- Postman (secret — keep private) ---
POSTMAN_API_KEY=YOUR_POSTMAN_API_KEY
POSTMAN_WORKSPACE_ID=YOUR_WORKSPACE_ID
